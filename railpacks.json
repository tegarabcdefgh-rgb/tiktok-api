{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "yt-dlp": {
      "commands": [
        "mkdir -p /app/bin",
        "curl -L https://github.com/yt-dlp/yt-dlp/releases/latest/download/yt-dlp -o /app/bin/yt-dlp",
        "chmod a+rx /app/bin/yt-dlp"
      ],
      "deployOutputs": ["/app/bin/yt-dlp"]
    }
  },
  "deploy": {
    "aptPackages": ["ffmpeg"]
  }
}